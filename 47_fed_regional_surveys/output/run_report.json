            },
            {
              "col": "GAF",
              "name": "future_general_activity"
            }
          ]
        }
      ]
    },
    "text": {
      "min_text_chars": 200,
      "ts_intro_sentence": "{bank} {survey_title} — monthly diffusion indices (current general activity, new orders, shipments, employment, prices paid/received; plus future general activity), trailing {n} months through {month}: <ts></ts>"
