          "district": 3,
          "domain": "manufacturing",
          "data_csv_url": "https://www.philadelphiafed.org/-/media/FRBP/Assets/Surveys-And-Data/MBOS/Historical-Data/Diffusion-Indexes/bos_dif.csv",
          "pdf_url_template": "https://www.philadelphiafed.org/-/media/frbp/assets/surveys-and-data/mbos/{year}/bos{mmyy}.pdf",
          "extractor": "mbos",
          "unit": "diffusion_index",
          "channels": [
            {
              "col": "GAC",
              "name": "general_activity"
            },
            {
              "col": "NOC",
